# Ignore build files
!*.v
!*.sv
!*.vh
!*.xdc
!*.tcl
.tmp_*.tcl
tools/write_debug_probes.tcl
uvhs/assign_pin_native_nutshell_f2.tcl
uvhs/probe.tcl
uvhs/uvhs_queue_ddr_workload.sh

fpga_*/
fpga_diff_uvhs_*/
src/tcl/cpu_files.tcl
src/tcl/chi_files.tcl

# Vivado local state and generated projects
.Xil/
*.jou
*.log
*.str
*.xpr
*.cache/
*.gen/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.srcs/

# UVHS/HJ generated working trees and exports. The source flow scripts live in
# uvhs/ and are intentionally not ignored.
uvhs_*/
uvhs_export*/
uvhs_test*/
runtime_uvhs_*/

# Local UVHS compatibility/tool payloads, not source flow scripts.
uvhs/setenv.local.sh
uvhs/*.local.sh
uvhs/uv_root_compat/
uvhs/libffi_compat/

