   676	static bool is_config_bar(struct xdma_dev *xdev, int idx, resource_size_t len)
   677	{
   678		u32 irq_id = 0;
   679		u32 cfg_id = 0;
   680		u32 mask = 0xffff0000; /* Compare only XDMA ID's not Version number */
   681		
   682		struct interrupt_regs *irq_regs =
   683			(struct interrupt_regs *)(xdev->bar[idx] + XDMA_OFS_INT_CTRL);
   684		struct config_regs *cfg_regs =
   685			(struct config_regs *)(xdev->bar[idx] + XDMA_OFS_CONFIG);
   686			
   687		if (len<XDMA_BAR_SIZE)
   688		{
   689			dbg_init("BAR %d is NOT the XDMA config BAR: 0x%x, 0x%x, len=%llu\n",
   690				 idx, irq_id, cfg_id, len);
   691			dbg_init("Hardware was not probed."); 
   692			return false; 
   693		}
   694	
   695		irq_id = read_register(&irq_regs->identifier);
   696		cfg_id = read_register(&cfg_regs->identifier);
   697	
   698		if (((irq_id & mask) == IRQ_BLOCK_ID) &&
   699		    ((cfg_id & mask) == CONFIG_BLOCK_ID)) {
   700			dbg_init("BAR %d is the XDMA config BAR\n", idx);
   701			return true;
   702		} else {
   703			dbg_init("BAR %d is NOT the XDMA config BAR: 0x%x, 0x%x, len=%llu\n",
   704				 idx, irq_id, cfg_id, len);
   705			return false;
   706		}
   707	
   708	}
   711	static int identify_bars(struct xdma_dev *xdev, int *bar_id_list, int num_bars,
   712				 int config_bar_pos)
   713	{
   714		/*
   715		 * The following logic identifies which BARs contain what functionality
   716		 * based on the position of the XDMA config BAR and the number of BARs
   717		 * detected. The rules are that the user logic and bypass logic BARs
   718		 * are optional.  When both are present, the XDMA config BAR will be the
   719		 * 2nd BAR detected (config_bar_pos = 1), with the user logic being
   720		 * detected first and the bypass being detected last. When one is
   721		 * omitted, the type of BAR present can be identified by whether the
   722		 * XDMA config BAR is detected first or last.  When both are omitted,
   723		 * only the XDMA config BAR is present.  This somewhat convoluted
   724		 * approach is used instead of relying on BAR numbers in order to work
   725		 * correctly with both 32-bit and 64-bit BARs.
   726		 */
   727	
   728		xdma_debug_assert_ptr(xdev);
   729	
   730		xdma_debug_assert_ptr(bar_id_list);
   731	
   732		dbg_init("xdev 0x%p, bars %d, config at %d.\n", xdev, num_bars,
   733			 config_bar_pos);
   734	
   735		switch (num_bars) {
   736		case 0:
   737		/* no bars were identified - probably wrong device*/
   738			pr_crit("No BARs were detected!\n");
   739			return -ENODEV;
   740		case 1:
   741			/* Only one BAR present - it must be config bar, but verify */
   742										
   743			if(config_bar_pos<0)
   744			{					
   745				if(is_config_bar(xdev, bar_id_list[0], xdev->bar_size[bar_id_list[0]] ))
   746					xdev->config_bar_idx=bar_id_list[0];
   747				else
   748					goto no_config_bar;
   749			}
   750			
   751			break;
   752	
   753		case 2:
   754			if(config_bar_pos<0)
   755			{
   756				pr_notice("Config bar num was invalid or not set. Falling back to autodetection.\n");
   757				/*  \/config bar 0 was already probed                      */
   758				if((config_bar_num!=0)&&is_config_bar(xdev, bar_id_list[0],  xdev->bar_size[bar_id_list[0]]))
   759				{
   760					xdev->config_bar_idx=bar_id_list[0];
   761					config_bar_pos=0;
   762				}					
   763				else if(is_config_bar(xdev, bar_id_list[1], xdev->bar_size[bar_id_list[1]] ))
   764				{
   765					xdev->config_bar_idx=bar_id_list[1];
   766					config_bar_pos=1;
   767				}
   768				else
   769					goto no_config_bar;
   770			}
   771			
   772			if (config_bar_pos == 0) {
   773				xdev->bypass_bar_idx = bar_id_list[1];
   774			} else if (config_bar_pos == 1) {
   775				xdev->user_bar_idx = bar_id_list[0];
   776			} else {
   777				pr_warn("2 BARs, XDMA config BAR unexpected %d.\n",
   778					config_bar_pos);
   779			}
   780			break;
   781	
   782		case 3:
   783		case 4:
   784			if(config_bar_pos<0)
   785			{//config bar must be in the middle - verify by probing expected position
   786				if ((num_bars==3)&&is_config_bar(xdev, bar_id_list[1], xdev->bar_size[bar_id_list[1]]))
   787				{
   788					xdev->config_bar_idx=bar_id_list[1];
   789					config_bar_pos=1;
   790				}
   791				else if ((num_bars==4)&&is_config_bar(xdev, bar_id_list[2], xdev->bar_size[bar_id_list[2]]))
   792				{
   793					xdev->config_bar_idx=bar_id_list[2];
   794					config_bar_pos=2;
   795				}
   796				else 
   797					goto no_config_bar;
   798			}
   799			if ((config_bar_pos == 1) || (config_bar_pos == 2)) {
   800				/* user bar at bar #0 */
   801				xdev->user_bar_idx = bar_id_list[0];
   802				/* bypass bar at the last bar */
   803				xdev->bypass_bar_idx = bar_id_list[num_bars - 1];
   804			} else {
   805				pr_warn("3/4 BARs, XDMA config BAR unexpected %d.\n",
   806					config_bar_pos);
   807			}
   808			break;
   809	
   810		default:
   811			if(xdev->config_bar_idx<0)
   812				goto no_config_bar;
   813			/* Should not occur - warn user but safe to continue */
   814			pr_warn("Unexpected # BARs (%d), XDMA config BAR only.\n",
   815				num_bars);
   816			break;
   817		}
   818		pr_info("%d BARs: config %d, user %d, bypass %d.\n", num_bars,
   819			xdev->config_bar_idx, xdev->user_bar_idx, xdev->bypass_bar_idx);
   820		return 0;
   821		
   822	no_config_bar:
   823		pr_err("Failed to detect XDMA config BAR\n");
   824		return -ENODEV;
   825	}
   826	
   827	
   828	/* map_bars() -- map device regions into kernel virtual address space
   829	 *
   830	 * Map the device memory regions into kernel virtual address space after
   831	 * verifying their sizes respect the minimum sizes needed
   832	 */
   833	static int map_bars(struct xdma_dev *xdev, struct pci_dev *dev)
   834	{
   835		int rv;
   836	
   837		int i;
   838		int bar_id_list[XDMA_BAR_NUM];
   839		int bar_id_idx = 0;
   840		int config_bar_pos = -1;
   841	
   842		/* iterate through all the BARs */
   843		for (i = 0; i < XDMA_BAR_NUM; i++) {
   844			resource_size_t bar_len =0;
   845			rv=map_single_bar(xdev, dev, i, &bar_len);
   846			/* if config_bar_num was set, make sure that the input was really set to config BAR*/
   847			if( (i==config_bar_num)&&is_config_bar(xdev, config_bar_num, bar_len) )
   848			{
   849				xdev->config_bar_idx = config_bar_num;
   850				config_bar_pos = bar_id_idx;
   851			}
   852			
   853			
   854			if (bar_len == 0) {
   855				continue;
   856			} else if (rv< 0) {
   857				rv = -EINVAL;
   858				goto fail;
   859			}
   860	
   861			bar_id_list[bar_id_idx] = i;
   862			bar_id_idx++;
   863		}
   864	
   865		rv = identify_bars(xdev, bar_id_list, bar_id_idx, config_bar_pos);
   866		if (unlikely(rv < 0)) {
   867			pr_err("Failed to identify bars\n");
   868			goto fail;
   869		}
   870	
   871		/* successfully mapped all required BAR regions */
   872		return 0;
   873	
   874	fail:
   875		/* unwind; unmap any BARs that we did map */
   876		unmap_bars(xdev, dev);
   877		return rv;
   878	}
