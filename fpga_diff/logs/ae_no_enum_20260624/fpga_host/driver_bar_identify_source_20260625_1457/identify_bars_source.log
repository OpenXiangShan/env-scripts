## libxdma.c map/is_config/identify snippets
   643	static int map_single_bar(struct xdma_dev *xdev, struct pci_dev *dev, int idx, resource_size_t *bar_len)
   644	{
   645		resource_size_t bar_start;
   646	
   647		bar_start = pci_resource_start(dev, idx);
   648		*bar_len = pci_resource_len(dev, idx);
   649	
   650		xdev->bar[idx] = NULL;
   651	
   652		/* do not map BARs with length 0. Note that start MAY be 0! */
   653		if (*bar_len==0) {
   654			//pr_info("BAR #%d is not present - skipping\n", idx);
   655			return 0;
   656		}
   657	
   658		/*
   659		 * map the full device memory or IO region into kernel virtual
   660		 * address space
   661		 */
   662		dbg_init("BAR%d: %llu bytes to be mapped.\n", idx, *bar_len);
   663		xdev->bar[idx] = pci_iomap(dev, idx, *bar_len);
   664	
   665		if (unlikely(!xdev->bar[idx])) {
   666			pr_info("Could not map BAR %d.\n", idx);
   667			return -1;
   668		}
   669		xdev->bar_size[idx] = *bar_len;
   670		pr_info("BAR%d at 0x%llx mapped at 0x%p, length=%llu\n", idx,
   671			(u64)bar_start, xdev->bar[idx],  *bar_len);
   672	
   673		return 0;
   674	}
